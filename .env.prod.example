# ─────────────────────────────────────────────────────────────────────────────
# Production-like deployment env. Copy to .env.prod, fill the REQUIRED secrets,
# then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build
#
# Note: DATABASE_URL, REDIS_URL and AWS_ENDPOINT_URL are injected by
# docker-compose.prod.yml (pointing at the db/redis/minio service hostnames),
# so they are intentionally NOT listed here.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_ENV=production
DEBUG=false

# Host port nginx is published on — this is the port you tunnel/share.
WEB_PORT=8080

# Postgres (db service)
POSTGRES_DB=dongaai
POSTGRES_USER=dev
POSTGRES_PASSWORD=change-me-db-password

# JWT — REQUIRED. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# Encryption (AES-256, license keys) — REQUIRED.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AES_SECRET_KEY=

# S3 / MinIO (these double as the MinIO root credentials)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change-me-minio-password
AWS_S3_BUCKET=dongaai
AWS_REGION=ap-northeast-2
