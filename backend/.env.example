# DB
DATABASE_URL=postgresql+asyncpg://dev:dev1234@localhost:5432/dongaai_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# S3 (MinIO for local dev)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=dongaai
AWS_REGION=ap-northeast-2
AWS_ENDPOINT_URL=http://localhost:9000

# Encryption (license keys AES-256)
AES_SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">

# App
APP_ENV=development
DEBUG=true
