# ──────────────────────────────────────────────────────────────
# 개발 전용 환경 변수 (git 커밋 가능 — 프로덕션 사용 금지)
# run-dev.bat 이 처음 실행될 때 .env 로 자동 복사됩니다.
# ──────────────────────────────────────────────────────────────

APP_ENV=development
DEBUG=true

# docker-compose.yml 기본값과 일치
DATABASE_URL=postgresql+asyncpg://dev:dev1234@localhost:5432/dongaai_dev
REDIS_URL=redis://localhost:6379/0

# 개발용 시크릿 (프로덕션 배포 시 반드시 교체)
SECRET_KEY=dev-only-secret-key-do-not-use-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# MinIO (로컬 S3 대체)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=dongaai-dev
AWS_REGION=ap-northeast-2
AWS_ENDPOINT_URL=http://localhost:9000

# 라이선스 키 암호화 (개발용)
AES_SECRET_KEY=dev-aes-key-local-only-do-not-use-in-prod
